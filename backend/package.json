{
  "name": "surveillance-backend",
  "version": "1.0.0",
  "description": "AI Video Surveillance Backend",
  "main": "dist/index.js",
  "scripts": {
    "predev": "lsof -t -i tcp:5000 -sTCP:LISTEN | xargs kill -9 2>/dev/null || true && prisma generate",
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:db-push": "prisma db push",
    "create-index": "ts-node src/create-index.ts",
    "setup-reid": "sh scripts/setup-reid-venv.sh",
    "export-reid-onnx": "python3 scripts/export-reid-onnx.py",
    "postbuild": "cp src/services/reid_worker.py dist/services/reid_worker.py"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@prisma/client": "^5.14.0",
    "@qdrant/js-client-rest": "^1.9.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.42.0",
    "sharp": "^0.33.5",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.12.12",
    "@types/ws": "^8.5.10",
    "nodemon": "^3.1.0",
    "prisma": "^5.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
