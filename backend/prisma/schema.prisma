datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

type OrgSettings {
  videoSummary     Boolean @default(true)
  semanticSearch   Boolean @default(true)
  aiChat           Boolean @default(true)
  reidProcessing   Boolean @default(true)
}

type EdgeDeviceConfig {
  yoloConfidence          Float?
  yoloDevice              String?
  yoloImgsz               Int?
  yoloDetectInterval      Int?
  cameraWidth             Int?
  cameraHeight            Int?
  cameraFps               Int?
  clipEncodeFps           Int?
  cameraStallTimeoutSec   Float?
  frameStreamFps          Float?
  previewJpegQuality      Int?
  previewStallTimeoutSec  Float?
  recordingMaxSec         Float?
  recordingEndGraceSec    Float?
  recordingCooldownSec    Float?
  minUploadDurationSec    Float?
  reidConfidenceThreshold Float?
  reidMinBboxSize         Int?
  reidVisibleSec          Float?
  debugLogs               Boolean?
}

model Organization {
  id               String                 @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  slug             String                 @unique
  settings         OrgSettings?
  createdAt        DateTime               @default(now())
  members          OrgMember[]
  devices          EdgeDevice[]
  identities       ReidIdentity[]
  topologyRoutes   TopologyRoute[]
  enrollmentTokens DeviceEnrollmentToken[]
}

model User {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  email        String      @unique
  passwordHash String
  name         String
  createdAt    DateTime    @default(now())
  memberships  OrgMember[]
}

model OrgMember {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  orgId     String       @db.ObjectId
  userId    String       @db.ObjectId
  role      String       @default("member") // owner | admin | member | viewer
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
}

model DeviceEnrollmentToken {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  orgId     String       @db.ObjectId
  token     String       @unique
  label     String?
  expiresAt DateTime?
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model VideoClip {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  filepath        String
  filename        String
  timestamp       DateTime        @default(now())
  summary         String
  duration        Float           @default(10.0)
  camera          String
  deviceId        String?
  streamId        String?
  detectedObjects Json?
  reidLog           Json?
  stream          CameraStream?   @relation(fields: [streamId], references: [streamId], onDelete: SetNull)
  detections      ReidDetection[]
}

model EdgeDevice {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  deviceId      String            @unique
  name          String
  status        String            @default("Offline") // "Offline", "Online"
  lastHeartbeat DateTime          @default(now())
  orgId         String?           @db.ObjectId
  config        EdgeDeviceConfig?
  org           Organization?     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  streams       CameraStream[]
}

model CameraStream {
  id                   String          @id @default(auto()) @map("_id") @db.ObjectId
  streamId             String          @unique
  deviceId             String
  device               EdgeDevice      @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)
  name                 String
  cameraType           String          @default("webcam") // "webcam" or "rtsp"
  streamUrl            String          @default("0")
  trackingEnabled      Boolean         @default(false)
  status               String          @default("Offline") // "Offline", "Idle", "Monitoring", "Recording", "Processing"
  motionThreshold      Int             @default(25)
  pixelChangeThreshold Float           @default(0.02)
  detectPerson         Boolean         @default(true)
  detectVehicle        Boolean         @default(true)
  streamHost           String          @default("")
  lastHeartbeat        DateTime        @default(now())
  clips                VideoClip[]
  detections           ReidDetection[]
  fromRoutes           TopologyRoute[] @relation("FromRoute")
  toRoutes             TopologyRoute[] @relation("ToRoute")
}

model ReidIdentity {
  id                  String                   @id @default(auto()) @map("_id") @db.ObjectId
  label               String?
  createdAt           DateTime                 @default(now())
  centroidUpdatedAt   DateTime?
  galleryCount        Int                      @default(0)
  orgId               String?                  @db.ObjectId
  org                 Organization?            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  detections          ReidDetection[]
  streamTrackMappings ReidStreamTrackMapping[]
}

model ReidStreamTrackMapping {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  streamId   String
  trackId    Int
  identityId String       @db.ObjectId
  identity   ReidIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([streamId, trackId])
}

model ReidDetection {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  deviceId     String
  cameraName   String
  streamId     String?
  stream       CameraStream? @relation(fields: [streamId], references: [streamId], onDelete: SetNull)
  trackId      Int
  timestamp    DateTime      @default(now())
  filename     String
  clipId       String?       @db.ObjectId
  clip         VideoClip?    @relation(fields: [clipId], references: [id], onDelete: SetNull)
  clipFilename String?
  clipOffsetMs Int?
  bbox         String        // "x1,y1,x2,y2"
  className    String
  identityId   String?       @db.ObjectId
  identity     ReidIdentity? @relation(fields: [identityId], references: [id], onDelete: SetNull)
}

model ReidFeedback {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  type              String   // "confirm" | "reject" | "same_person" | "different_person"
  sourceDetectionId String   @db.ObjectId
  targetDetectionId String   @db.ObjectId
  createdAt         DateTime @default(now())
}

model TopologyRoute {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  fromCamera     String
  toCamera       String
  fromStreamId   String?
  toStreamId     String?
  fromStream     CameraStream? @relation("FromRoute", fields: [fromStreamId], references: [streamId], onDelete: SetNull)
  toStream       CameraStream? @relation("ToRoute", fields: [toStreamId], references: [streamId], onDelete: SetNull)
  minTimeSeconds Float
  maxTimeSeconds Float
  topologyScore  Float         @default(1.0)
  orgId          String?       @db.ObjectId
  org            Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

