# Aura Watch AI - Backend Environment Variables Template

# Server Port and Environment
PORT=5000
NODE_ENV=development

# JWT authentication (required for multi-org)
JWT_SECRET="change-this-to-a-random-secret-in-production"
JWT_EXPIRES_IN=7d

# Optional: seed a bootstrap admin on first startup
# BOOTSTRAP_ADMIN_EMAIL=admin@localhost
# BOOTSTRAP_ADMIN_PASSWORD=your-secure-password

# Super admin console (/admin) — fixed password for viewing all orgs and impersonation
SUPER_ADMIN_PASSWORD=aura-admin

# MongoDB Connection String (via Prisma)
# Example: mongodb://username:password@host:port/dbname?authSource=admin&directConnection=true
DATABASE_URL="mongodb://localhost:27017/aura-watch?authSource=admin"

# Qdrant Vector Database Connection
# Local: http://localhost:6333
# Reverse proxy (Nginx Proxy Manager): https://qdrant.yourdomain.com (use https; client maps to port 443)
QDRANT_URL=http://localhost:6333
# Set your Qdrant API Key (leave empty for local instances without authentication)
QDRANT_API_KEY=""

# AI Provider Selection ('openai', 'openrouter', or 'gemini')
# Defines the provider used for generating text embeddings and/or summaries
AI_PROVIDER=gemini

# Google Gemini API Key (Required for Video clip summarization via Gemini)
GEMINI_API_KEY="your_google_gemini_api_key_here"

# OpenAI API Key (Required if AI_PROVIDER is set to 'openai')
OPENAI_API_KEY="your_openai_api_key_here"

# OpenRouter API Key (Required if AI_PROVIDER is set to 'openrouter')
OPENROUTER_API_KEY="your_openrouter_api_key_here"
# Free chat/tools model (auto-selects a free model with required capabilities)
OPENROUTER_MODEL=openrouter/free
# Free video model (supports native video input; still free to use)
OPENROUTER_VIDEO_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
# Set to false to skip native video and use up to 10 extracted frames instead
# OPENROUTER_USE_NATIVE_VIDEO=false
# Embedding model (no free option on OpenRouter; qwen is low-cost)
OPENROUTER_EMBEDDING_MODEL=qwen/qwen3-embedding-8b

# Local Storage Directory for temporary video uploads
VIDEO_STORAGE_DIR="./storage/videos"

# ReID worker (ONNX Runtime — optional overrides)
# Run: npm run setup-reid
# REID_PYTHON="./.venv-reid/bin/python"
# REID_MODEL_PATH="./models/osnet_x1_0.onnx"
