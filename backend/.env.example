# Aura Watch AI - Backend Environment Variables Template

# Server Port and Environment
PORT=5000
NODE_ENV=development

# MongoDB Connection String (via Prisma)
# Example: mongodb://username:password@host:port/dbname?authSource=admin&directConnection=true
DATABASE_URL="mongodb://localhost:27017/aura-watch?authSource=admin"

# Qdrant Vector Database Connection
# Set to your cloud cluster URL or local running instance (default local: http://localhost:6333)
QDRANT_URL=http://localhost:6333
# Set your Qdrant API Key (leave empty for local instances without authentication)
QDRANT_API_KEY=""

# AI Provider Selection ('openai' or 'gemini')
# Defines the provider used for generating text embeddings and/or summaries
AI_PROVIDER=gemini

# Google Gemini API Key (Required for Video clip summarization via Gemini)
GEMINI_API_KEY="your_google_gemini_api_key_here"

# OpenAI API Key (Required if AI_PROVIDER is set to 'openai')
OPENAI_API_KEY="your_openai_api_key_here"

# Local Storage Directory for temporary video uploads
VIDEO_STORAGE_DIR="./storage/videos"
