# Cloud Hub API server configurations
CLOUD_URL=https://aura-watch.adboardtools.com

# Edge Device details (Optional, defaults will be used if omitted)
DEVICE_NAME="Office Edge Pi"

# Local Storage (where recorded 10s clips are saved temporarily before upload)
LOCAL_VIDEO_DIR=./storage/temp_clips

# Gemini Video Upload Optimization Settings
GEMINI_OPTIMIZE=true
GEMINI_OPTIMIZE_FPS=1
GEMINI_OPTIMIZE_RESOLUTION=640:480
GEMINI_OPTIMIZE_CRF=28

# Control whether verbose FFmpeg output/errors are logged in the console (true/false)
DEBUG_LOGS=true

# Camera capture resolution (lower = faster inference + encoding)
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30

# YOLO + ByteTrack settings
YOLO_CONFIDENCE=0.25
# auto | cpu | mps | cuda
YOLO_DEVICE=auto
# Inference input size (416 is faster than 640)
YOLO_IMGSZ=416
# Run full detection every N frames; intermediate frames reuse last boxes
YOLO_DETECT_INTERVAL=3
# Optional optimized model (auto-used when file exists):
#   macOS:     ./yolov8n.mlpackage  (export: python scripts/export_model.py coreml)
#   Pi / ARM:  ./yolov8n.onnx       (export: python scripts/export_model.py onnx)
#   Jetson:    ./yolov8n.engine     (export: python scripts/export_model.py engine)
#   Intel CPU: ./yolov8n_openvino_model (export: python scripts/export_model.py openvino)
# YOLO_MODEL_PATH=./yolov8n.onnx
# YOLO_USE_TENSORRT=true
# YOLO_USE_OPENVINO=true
# Comma-separated COCO classes; "vehicle" expands to bicycle,car,motorcycle,bus,truck
YOLO_CLASSES=person,vehicle

# Low-latency WebSocket preview (frames per second to UI)
FRAME_STREAM_FPS=12
PREVIEW_JPEG_QUALITY=70

# Direct HTTP HLS server on the edge (backend fetches segments over HTTP instead of WS)
EDGE_HTTP_PORT=8090
# Optional: override advertised host (defaults to LAN IP)
# EDGE_HTTP_HOST=192.168.18.69

# HLS segment duration in seconds (used for clip recording; live UI uses WebSocket)
HLS_SEGMENT_SEC=1

# Record while objects are visible, up to this many seconds per clip
RECORDING_MAX_SEC=60

# Seconds without detections before ending a clip
RECORDING_END_GRACE_SEC=2

# Seconds to wait after a clip finishes uploading before allowing another recording
RECORDING_COOLDOWN_SEC=45

# RTSP transport: tcp, udp, or auto (tries tcp then udp)
RTSP_TRANSPORT=tcp

# Optional: bind RTSP client to a specific local interface IP (e.g. 192.168.18.69)
# RTSP_LOCAL_ADDR=192.168.18.69
