# Cloud Hub API server configurations
CLOUD_URL=http://localhost:5000
CLOUD_WS_URL=ws://localhost:5000

# Edge Device details (Optional, defaults will be used if omitted)
DEVICE_NAME="Office Edge Pi"

# Local Storage (where recorded 10s clips are saved temporarily before upload)
LOCAL_VIDEO_DIR=./storage/temp_clips

# Gemini Video Upload Optimization Settings
GEMINI_OPTIMIZE=true
GEMINI_OPTIMIZE_FPS=1
GEMINI_OPTIMIZE_RESOLUTION=640:480
GEMINI_OPTIMIZE_CRF=28

# Control whether verbose FFmpeg output/errors are logged in the console (true/false)
DEBUG_LOGS=true
